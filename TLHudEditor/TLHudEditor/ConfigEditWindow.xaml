<Window 
    x:Class="TLHudEditor.ConfigEditWindow" 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" 
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:local="clr-namespace:TLHudEditor" 
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" 
    mc:Ignorable="d" 
    WindowStyle="None" 
    Height="370"
    Width="520" 
    WindowStartupLocation="CenterScreen" 
    ResizeMode="NoResize" 
    Topmost="True" 
    Background="Transparent" 
    AllowsTransparency="True" 
    Title="TL HUD Editor" 
    Closed="OnWindowClosed">
    <Border BorderThickness="1" BorderBrush="#FF282828" Background="#FF141414" CornerRadius="3" MouseLeftButtonDown="MoveWindow">
        <StackPanel Margin="10">
            <TextBlock Text="Компонент" Foreground="#FFB0B0B0" FontSize="12" Margin="0 0 0 4" />
            <ComboBox x:Name="FramesList" DisplayMemberPath="Value" SelectedValuePath="Key" FontSize="14" SelectionChanged="FramesListSelectionChanged" />

            <TextBlock Text="Выравнивание" Foreground="#FFB0B0B0" FontSize="12" Margin="0 10 0 4" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="AlignCombo" FontSize="14" SelectionChanged="AlignComboSelectionChanged" VerticalAlignment="Center" />
                <Button Grid.Column="1" Style="{StaticResource ConfigResetButtonStyle}" Click="ResetFieldButtonClick" Tag="Align">
                    <ui:SymbolIcon Style="{StaticResource SoloHoverableSymbolIconStyle}" Symbol="ArrowClockwiseDashes24" />
                </Button>
            </Grid>

            <Grid Margin="0 10 0 0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Ширина:" Foreground="#FFB0B0B0" FontSize="12" VerticalAlignment="Center" />
                    <TextBlock x:Name="TxtDesiredWidth" Foreground="White" FontSize="12" Margin="4 0 0 0" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="Высота:" Foreground="#FFB0B0B0" FontSize="12" VerticalAlignment="Center" />
                    <TextBlock x:Name="TxtDesiredHeight" Foreground="White" FontSize="12" Margin="4 0 0 0" VerticalAlignment="Center" />
                </StackPanel>
                <Grid Grid.Row="1" Grid.Column="0" Margin="0 2 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="SliderDesiredWidth" Grid.Column="0" Minimum="0" Maximum="4096" SmallChange="1" LargeChange="32" VerticalAlignment="Center" ValueChanged="NumericSliderValueChanged" />
                    <Button Grid.Column="1" Style="{StaticResource ConfigResetButtonStyle}" Click="ResetFieldButtonClick" Tag="DesiredWidth">
                        <ui:SymbolIcon Style="{StaticResource SoloHoverableSymbolIconStyle}" Symbol="ArrowClockwiseDashes24" />
                    </Button>
                </Grid>
                <Grid Grid.Row="1" Grid.Column="2" Margin="0 2 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="SliderDesiredHeight" Grid.Column="0" Minimum="0" Maximum="4096" SmallChange="1" LargeChange="32" VerticalAlignment="Center" ValueChanged="NumericSliderValueChanged" />
                    <Button Grid.Column="1" Style="{StaticResource ConfigResetButtonStyle}" Click="ResetFieldButtonClick" Tag="DesiredHeight">
                        <ui:SymbolIcon Style="{StaticResource SoloHoverableSymbolIconStyle}" Symbol="ArrowClockwiseDashes24" />
                    </Button>
                </Grid>
            </Grid>
            <Grid Margin="0 6 0 0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="X:" Foreground="#FFB0B0B0" FontSize="12" VerticalAlignment="Center" />
                    <TextBlock x:Name="TxtTranslateX" Foreground="White" FontSize="12" Margin="4 0 0 0" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="Y:" Foreground="#FFB0B0B0" FontSize="12" VerticalAlignment="Center" />
                    <TextBlock x:Name="TxtTranslateY" Foreground="White" FontSize="12" Margin="4 0 0 0" VerticalAlignment="Center" />
                </StackPanel>
                <Grid Grid.Row="1" Grid.Column="0" Margin="0 2 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="SliderTranslateX" Grid.Column="0" Minimum="-3000" Maximum="3000" SmallChange="1" LargeChange="50" VerticalAlignment="Center" ValueChanged="NumericSliderValueChanged" />
                    <Button Grid.Column="1" Style="{StaticResource ConfigResetButtonStyle}" Click="ResetFieldButtonClick" Tag="TranslateX">
                        <ui:SymbolIcon Style="{StaticResource SoloHoverableSymbolIconStyle}" Symbol="ArrowClockwiseDashes24" />
                    </Button>
                </Grid>
                <Grid Grid.Row="1" Grid.Column="2" Margin="0 2 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="SliderTranslateY" Grid.Column="0" Minimum="-3000" Maximum="3000" SmallChange="1" LargeChange="50" VerticalAlignment="Center" ValueChanged="NumericSliderValueChanged" />
                    <Button Grid.Column="1" Style="{StaticResource ConfigResetButtonStyle}" Click="ResetFieldButtonClick" Tag="TranslateY">
                        <ui:SymbolIcon Style="{StaticResource SoloHoverableSymbolIconStyle}" Symbol="ArrowClockwiseDashes24" />
                    </Button>
                </Grid>
            </Grid>
            <Grid Margin="0 6 0 0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Масштаб (XYZ):" Foreground="#FFB0B0B0" FontSize="12" VerticalAlignment="Center" />
                    <TextBlock x:Name="TxtScale" Foreground="White" FontSize="12" Margin="4 0 0 0" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="2" Orientation="Horizontal">
                    <TextBlock Text="Z-порядок:" Foreground="#FFB0B0B0" FontSize="12" VerticalAlignment="Center" />
                    <TextBlock x:Name="TxtZOrder" Foreground="White" FontSize="12" Margin="4 0 0 0" VerticalAlignment="Center" />
                </StackPanel>
                <Grid Grid.Row="1" Grid.Column="0" Margin="0 2 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="SliderScaleUniform" Grid.Column="0" Minimum="0" Maximum="4" SmallChange="0.05" LargeChange="0.25" VerticalAlignment="Center" ValueChanged="NumericSliderValueChanged" />
                    <Button Grid.Column="1" Style="{StaticResource ConfigResetButtonStyle}" Click="ResetFieldButtonClick" Tag="Scale">
                        <ui:SymbolIcon Style="{StaticResource SoloHoverableSymbolIconStyle}" Symbol="ArrowClockwiseDashes24" />
                    </Button>
                </Grid>
                <Grid Grid.Row="1" Grid.Column="2" Margin="0 2 0 0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Slider x:Name="SliderZOrder" Grid.Column="0" Minimum="0" Maximum="1000" SmallChange="1" LargeChange="10" VerticalAlignment="Center" ValueChanged="NumericSliderValueChanged" />
                    <Button Grid.Column="1" Style="{StaticResource ConfigResetButtonStyle}" Click="ResetFieldButtonClick" Tag="ZOrder">
                        <ui:SymbolIcon Style="{StaticResource SoloHoverableSymbolIconStyle}" Symbol="ArrowClockwiseDashes24" />
                    </Button>
                </Grid>
            </Grid>
            
            <Button x:Name="SaveButton" Content="Сохранить" Height="36" MinWidth="120" Click="SaveButtonClick" Cursor="Hand" HorizontalAlignment="Stretch" Margin="0 10 0 0" Padding="16 0" />
        </StackPanel>
    </Border>
</Window>
